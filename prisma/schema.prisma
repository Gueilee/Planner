generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

// ─────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────

enum UserRole {
  ADMIN
  DIRECTOR
  PROJECT_MANAGER
  PROJECT_MEMBER
  SPONSOR
  CLIENT
}


enum ProjectStatus {
  PLANNING
  IN_PROGRESS
  PILOT
  RAMP_UP
  GO_LIVE
  POST_GOLIVE
  COMPLETED
  CANCELLED
  ON_HOLD
  FUTURE_ANALYSIS
}

enum TaskStatus {
  INITIATIVE
  PLANNING
  IN_PROGRESS
  VALIDATION
  COMPLETED
  ON_HOLD
  DELAYED
}

enum RiskLevel {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum MeetingType {
  CHECKPOINT
  STATUS_REPORT
  GO_NO_GO
  KICKOFF
  PILOT
  GO_LIVE
  POST_GOLIVE
  LESSONS_LEARNED
  PROJECT_CLOSURE
  OTHER
}

enum DocumentType {
  PROJECT_OPENING
  PROJECT_CLOSURE
  LESSONS_LEARNED_DOC
  STATUS_REPORT_DOC
  GO_NO_GO_DECISION
  TECHNICAL_PRESENTATION
  KICKOFF
}

enum LessonType {
  GOOD_PRACTICE
  PROBLEM
}

enum ProjectPhase {
  INITIATION
  PLANNING
  EXECUTION
  MONITORING
  CLOSURE
}

enum LessonInfluence {
  POSITIVE
  NEGATIVE
  NEUTRAL
}

enum LessonImpact {
  HIGH
  MEDIUM
  LOW
}

enum PostGoLiveItemType {
  ADJUSTMENT
  IMPROVEMENT
  ISSUE
  KPI
}

// ─────────────────────────────────────────────
// AUTH
// ─────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String
  role          UserRole  @default(PROJECT_MEMBER)
  department    String?
  phone         String?
  active        Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  projectMemberships   ProjectMember[]
  sponsoredProjects    Project[]         @relation("ProjectSponsor")
  assignedTasks        ScheduleTask[]    @relation("TaskResponsible")
  comments             Comment[]
  createdMeetings      Meeting[]         @relation("MeetingCreator")
  createdReports       StatusReport[]
  createdDocuments     ProjectDocument[]
  notifications        Notification[]
  lessonsLearned       LessonLearned[]
}

// ─────────────────────────────────────────────
// PROJECTS
// ─────────────────────────────────────────────

model Project {
  id           String        @id @default(cuid())
  title        String
  description  String?
  status       ProjectStatus @default(PLANNING)

  // Planning / intake fields (previously on Initiative)
  origin         String?
  scope          String?
  asIs           String?
  toBe           String?
  assumptions    String?
  restrictions   String?
  budget         Float?
  estimatedCosts Float?
  economy        Float?
  expectedStart  DateTime?
  expectedEnd    DateTime?

  // Sponsor
  sponsorId String?
  sponsor   User?   @relation("ProjectSponsor", fields: [sponsorId], references: [id])

  actualStart DateTime?
  actualEnd   DateTime?
  goLiveDate  DateTime?

  // Roadmap ordering
  roadmapOrder   Int?
  roadmapYear    Int?
  roadmapQuarter Int?

  // Post-GoLive
  goLiveActual      DateTime?
  postGoLiveEndDate DateTime?

  // Priority
  priority          Int?
  priorityLabel     String?
  priorityNotes     String?
  priorityUpdatedAt DateTime?

  // Status Report indicators (GREEN | YELLOW | RED)
  reportStatusCost      String  @default("GREEN")
  reportStatusSchedule  String  @default("GREEN")
  reportStatusResources String  @default("GREEN")
  reportStatusOverall   String  @default("GREEN")
  reportStatusNotes     String?

  members        ProjectMember[]
  wbsAreas       WbsArea[]
  tasks          ScheduleTask[]
  meetings       Meeting[]
  risks          Risk[]
  statusReports  StatusReport[]
  documents      ProjectDocument[]
  postGoLiveItems PostGoLiveItem[]
  lessonsLearned LessonLearned[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ProjectMember {
  id        String  @id @default(cuid())
  projectId String
  userId    String
  role      String

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id])

  addedAt DateTime @default(now())

  @@unique([projectId, userId])
}

// ─────────────────────────────────────────────
// WBS — Estrutura Analítica do Projeto
// ─────────────────────────────────────────────

model WbsArea {
  id          String  @id @default(cuid())
  projectId   String
  name        String
  description String?
  color       String?
  order       Int     @default(0)

  project Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  tasks   ScheduleTask[]

  createdAt DateTime @default(now())
}

// ─────────────────────────────────────────────
// SCHEDULE — Cronograma
// ─────────────────────────────────────────────

model ScheduleTask {
  id          String    @id @default(cuid())
  projectId   String
  wbsAreaId   String?
  parentId    String?
  title       String
  description String?

  responsibleId String?
  startDate     DateTime?
  endDate       DateTime?
  completedAt   DateTime?

  status     TaskStatus @default(PLANNING)
  riskStatus RiskLevel  @default(LOW)
  progress   Int        @default(0)
  order      Int        @default(0)

  // Dependency IDs as JSON array
  dependencies String?

  project     Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  wbsArea     WbsArea?      @relation(fields: [wbsAreaId], references: [id])
  parent      ScheduleTask?  @relation("TaskHierarchy", fields: [parentId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  subtasks    ScheduleTask[] @relation("TaskHierarchy")
  responsible User?         @relation("TaskResponsible", fields: [responsibleId], references: [id])

  comments    Comment[]
  attachments Attachment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─────────────────────────────────────────────
// RISKS
// ─────────────────────────────────────────────

model Risk {
  id          String    @id @default(cuid())
  projectId   String
  description String
  probability String
  impact      String
  mitigation  String?
  status      RiskLevel @default(LOW)
  owner       String?

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─────────────────────────────────────────────
// MEETINGS — Atas e Reuniões
// ─────────────────────────────────────────────

model Meeting {
  id          String      @id @default(cuid())
  projectId   String
  type        MeetingType
  title       String
  date        DateTime
  location    String?
  content     String?
  decisions   String?
  nextActions String?

  createdById String
  createdBy   User    @relation("MeetingCreator", fields: [createdById], references: [id])
  project     Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  participants MeetingParticipant[]
  attachments  Attachment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model MeetingParticipant {
  id        String @id @default(cuid())
  meetingId String
  userId    String

  meeting Meeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)

  @@unique([meetingId, userId])
}

// ─────────────────────────────────────────────
// STATUS REPORTS
// ─────────────────────────────────────────────

model StatusReport {
  id          String   @id @default(cuid())
  projectId   String
  periodStart DateTime
  periodEnd   DateTime

  summary       String?
  highlights    String?
  risks         String?
  nextSteps     String?
  overallStatus String  @default("GREEN")

  tasksTotal     Int   @default(0)
  tasksCompleted Int   @default(0)
  tasksPending   Int   @default(0)
  tasksDelayed   Int   @default(0)
  budgetUsed     Float?

  pdfUrl String?

  createdById String
  createdBy   User    @relation(fields: [createdById], references: [id])
  project     Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
}

// ─────────────────────────────────────────────
// DOCUMENTS
// ─────────────────────────────────────────────

model ProjectDocument {
  id        String       @id @default(cuid())
  projectId String
  type      DocumentType
  title     String
  content   String?
  pdfUrl    String?
  version   Int          @default(1)

  createdById String
  createdBy   User    @relation(fields: [createdById], references: [id])
  project     Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─────────────────────────────────────────────
// POST GO LIVE
// ─────────────────────────────────────────────

model PostGoLiveItem {
  id          String             @id @default(cuid())
  projectId   String
  date        DateTime
  type        PostGoLiveItemType
  description String
  status      String             @default("OPEN")
  kpiData     String?

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
}

// ─────────────────────────────────────────────
// LESSONS LEARNED
// ─────────────────────────────────────────────

model LessonLearned {
  id           String          @id @default(cuid())
  projectId    String
  phase        ProjectPhase    @default(EXECUTION)
  area         String
  responsible  String
  occurrence   String
  influence    LessonInfluence @default(POSITIVE)
  impact       LessonImpact    @default(MEDIUM)
  lesson       String
  identifiedAt DateTime        @default(now())
  tags         String?

  createdById String
  createdBy   User    @relation(fields: [createdById], references: [id])
  project     Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─────────────────────────────────────────────
// COMMENTS & ATTACHMENTS
// ─────────────────────────────────────────────

model Comment {
  id        String   @id @default(cuid())
  taskId    String
  userId    String
  content   String

  task        ScheduleTask @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user        User         @relation(fields: [userId], references: [id])
  attachments Attachment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Attachment {
  id        String @id @default(cuid())
  fileName  String
  fileUrl   String
  fileType  String
  fileSize  Int?

  taskId    String?
  commentId String?
  meetingId String?

  task    ScheduleTask? @relation(fields: [taskId], references: [id], onDelete: Cascade)
  comment Comment?      @relation(fields: [commentId], references: [id], onDelete: Cascade)
  meeting Meeting?      @relation(fields: [meetingId], references: [id], onDelete: Cascade)

  uploadedAt DateTime @default(now())
}

// ─────────────────────────────────────────────
// NOTIFICATIONS
// ─────────────────────────────────────────────

model Notification {
  id      String  @id @default(cuid())
  userId  String
  type    String
  title   String
  message String
  link    String?
  read    Boolean @default(false)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
}
