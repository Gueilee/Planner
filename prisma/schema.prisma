generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

// ─────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────

enum UserRole {
  ADMIN
  DIRECTOR
  PROJECT_MANAGER
  PROJECT_MEMBER
  SPONSOR
  CLIENT
}


enum ProjectStatus {
  PENDING_GO_NO_GO
  PLANNING
  IN_PROGRESS
  PILOT
  RAMP_UP
  GO_LIVE
  POST_GOLIVE
  COMPLETED
  CANCELLED
  ON_HOLD
  FUTURE_ANALYSIS
  PAUSED
}

enum TaskStatus {
  INITIATIVE
  PLANNING
  IN_PROGRESS
  VALIDATION
  COMPLETED
  ON_HOLD
  DELAYED
}

enum RiskLevel {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum MeetingType {
  CHECKPOINT
  STATUS_REPORT
  GO_NO_GO
  KICKOFF
  PILOT
  GO_LIVE
  POST_GOLIVE
  LESSONS_LEARNED
  PROJECT_CLOSURE
  OTHER
}

enum DocumentType {
  PROJECT_OPENING
  PROJECT_CLOSURE
  LESSONS_LEARNED_DOC
  STATUS_REPORT_DOC
  GO_NO_GO_DECISION
  TECHNICAL_PRESENTATION
  KICKOFF
  MEETING_ATA
  KICKOFF_PRESENTATION
}

enum LessonType {
  GOOD_PRACTICE
  PROBLEM
}

enum ProjectPhase {
  INITIATION
  PLANNING
  EXECUTION
  MONITORING
  CLOSURE
}

enum LessonInfluence {
  POSITIVE
  NEGATIVE
  NEUTRAL
}

enum LessonImpact {
  HIGH
  MEDIUM
  LOW
}

enum PostGoLiveItemType {
  ADJUSTMENT
  IMPROVEMENT
  ISSUE
  KPI
}

enum ProjectArea {
  TECNOLOGIA
  QUALIDADE
  ESTRATEGICO
}

enum BenefitCategory {
  FINANCIAL
  OPERATIONAL
  STRATEGIC
}

enum BenefitType {
  // Financial
  COST_REDUCTION
  REVENUE_INCREASE
  OPEX_REDUCTION
  ANNUAL_SAVINGS
  MONTHLY_SAVINGS
  // Operational
  HOURS_SAVED
  PRODUCTIVITY_GAIN
  PROCESS_AUTOMATION
  REWORK_REDUCTION
  TIME_REDUCTION
  // Strategic
  CUSTOMER_EXPERIENCE
  RISK_REDUCTION
  COMPLIANCE
  QUALITY
  GOVERNANCE
  USER_SATISFACTION
  // Other
  OTHER
}

enum BenefitFrequency {
  ONCE
  MONTHLY
  ANNUAL
}

enum BenefitStatus {
  PLANNED
  IN_PROGRESS
  REALIZED
  NOT_REALIZED
}

// ─────────────────────────────────────────────
// AUTH
// ─────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String
  role          UserRole  @default(PROJECT_MEMBER)
  department    String?
  phone         String?
  active        Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  projectMemberships   ProjectMember[]
  sponsoredProjects    Project[]         @relation("ProjectSponsor")
  assignedTasks        ScheduleTask[]    @relation("TaskResponsible")
  comments             Comment[]
  createdMeetings      Meeting[]         @relation("MeetingCreator")
  meetingParticipations MeetingParticipant[]
  createdReports       StatusReport[]
  createdDocuments     ProjectDocument[]
  notifications           Notification[]
  notificationPreference  NotificationPreference?
  lessonsLearned          LessonLearned[]
  scheduleTemplates       ScheduleTemplate[]
  createdBenefits         ProjectBenefit[]
  createdMeasurements     BenefitMeasurement[]
  timeEntries             TimeEntry[]
  baselines               ProjectBaseline[]
}

// ─────────────────────────────────────────────
// PROJECTS
// ─────────────────────────────────────────────

model Project {
  id           String        @id @default(cuid())
  title        String
  description  String?
  status       ProjectStatus @default(PLANNING)
  projectArea  ProjectArea   @default(TECNOLOGIA)

  // Planning / intake fields (previously on Initiative)
  origin         String?
  proposalNumber String?   // Nº proposta comercial aprovada (projetos CLIENT)
  contractNumber String?   // Nº do contrato ou pedido de venda (projetos CLIENT)
  scope          String?
  asIs           String?
  toBe           String?
  assumptions    String?
  restrictions   String?
  budget         Float?
  estimatedCosts Float?
  economy        Float?
  expectedStart  DateTime?
  expectedEnd    DateTime?

  // Sponsor
  sponsorId String?
  sponsor   User?   @relation("ProjectSponsor", fields: [sponsorId], references: [id])

  // Team analysis — suggested dates after reviewing the request
  suggestedStart DateTime?
  suggestedEnd   DateTime?

  actualStart DateTime?
  actualEnd   DateTime?
  goLiveDate  DateTime?

  // Roadmap ordering
  roadmapOrder   Int?
  roadmapYear    Int?
  roadmapQuarter Int?

  // Post-GoLive
  goLiveActual      DateTime?
  postGoLiveEndDate DateTime?

  // Benefits — investimento do projeto para cálculo de ROI
  investment Float @default(0)

  // Priority
  priority          Int?
  priorityLabel     String?
  priorityNotes     String?
  priorityUpdatedAt DateTime?

  // Sequential request number — VDM-NNNN format, unique across all projects
  requestNumber Int? @unique

  // Status Report indicators (GREEN | YELLOW | RED)
  reportStatusCost      String  @default("GREEN")
  reportStatusSchedule  String  @default("GREEN")
  reportStatusResources String  @default("GREEN")
  reportStatusOverall   String  @default("GREEN")
  reportStatusNotes     String?
  // When true the user has manually overridden the auto-computed status — skip auto-overwrite
  reportStatusManual    Boolean @default(false)

  members        ProjectMember[]
  wbsAreas       WbsArea[]
  tasks          ScheduleTask[]
  meetings       Meeting[]
  risks          Risk[]
  statusReports  StatusReport[]
  documents      ProjectDocument[]
  postGoLiveItems PostGoLiveItem[]
  lessonsLearned LessonLearned[]
  attachments    Attachment[]
  benefits       ProjectBenefit[]
  baselines      ProjectBaseline[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ProjectMember {
  id        String  @id @default(cuid())
  projectId String
  userId    String
  role      String

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id])

  addedAt DateTime @default(now())

  @@unique([projectId, userId])
}

// ─────────────────────────────────────────────
// WBS — Estrutura Analítica do Projeto
// ─────────────────────────────────────────────

model WbsArea {
  id          String  @id @default(cuid())
  projectId   String
  name        String
  description String?
  color       String?
  order       Int     @default(0)
  weight      Float?  // 0-100 — peso do módulo no progresso ponderado do projeto

  project Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  tasks   ScheduleTask[]

  createdAt DateTime @default(now())
}

// ─────────────────────────────────────────────
// SCHEDULE — Cronograma
// ─────────────────────────────────────────────

model ScheduleTask {
  id          String    @id @default(cuid())
  projectId   String
  wbsAreaId   String?
  parentId    String?
  title       String
  description String?

  responsibleId String?
  startDate     DateTime?
  endDate       DateTime?
  actualStart   DateTime?
  actualEnd     DateTime?
  completedAt   DateTime?

  estimatedEffort Float?   // horas estimadas pelo analista
  actualEffort    Float?   // horas realizadas pelo responsável
  budgetedCost    Float?   // R$ orçado para esta atividade
  actualCost      Float?   // R$ real gasto nesta atividade

  status     TaskStatus @default(PLANNING)
  riskStatus RiskLevel  @default(LOW)
  progress   Int        @default(0)
  order      Int        @default(0)

  // Dependency IDs as JSON array
  dependencies String?

  project     Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  wbsArea     WbsArea?      @relation(fields: [wbsAreaId], references: [id])
  parent      ScheduleTask?  @relation("TaskHierarchy", fields: [parentId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  subtasks    ScheduleTask[] @relation("TaskHierarchy")
  responsible User?         @relation("TaskResponsible", fields: [responsibleId], references: [id])

  comments    Comment[]
  attachments Attachment[]
  timeEntries TimeEntry[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─────────────────────────────────────────────
// TIME ENTRIES — Apontamento de Horas
// ─────────────────────────────────────────────

model TimeEntry {
  id        String       @id @default(cuid())
  taskId    String
  userId    String
  hours     Float
  date      DateTime     @default(now())
  note      String?
  createdAt DateTime     @default(now())

  task ScheduleTask @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user User         @relation(fields: [userId], references: [id])

  @@index([taskId])
  @@index([userId])
}

// ─────────────────────────────────────────────
// RISKS
// ─────────────────────────────────────────────

model Risk {
  id          String    @id @default(cuid())
  projectId   String
  description String
  probability String
  impact      String
  mitigation  String?
  status      RiskLevel @default(LOW)
  owner       String?

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─────────────────────────────────────────────
// MEETINGS — Atas e Reuniões
// ─────────────────────────────────────────────

model Meeting {
  id          String      @id @default(cuid())
  projectId   String
  type        MeetingType
  title       String
  date        DateTime
  location    String?
  content      String?
  decisions    String?
  nextActions  String?
  observations String?

  createdById String
  createdBy   User    @relation("MeetingCreator", fields: [createdById], references: [id])
  project     Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  participants MeetingParticipant[]
  attachments  Attachment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model MeetingParticipant {
  id        String @id @default(cuid())
  meetingId String
  userId    String

  meeting Meeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id])

  @@unique([meetingId, userId])
}

// ─────────────────────────────────────────────
// STATUS REPORTS
// ─────────────────────────────────────────────

model StatusReport {
  id          String   @id @default(cuid())
  projectId   String
  periodStart DateTime
  periodEnd   DateTime

  summary       String?
  highlights    String?
  risks         String?
  nextSteps     String?
  overallStatus String  @default("GREEN")

  tasksTotal     Int   @default(0)
  tasksCompleted Int   @default(0)
  tasksPending   Int   @default(0)
  tasksDelayed   Int   @default(0)
  budgetUsed     Float?

  pdfUrl String?

  createdById String
  createdBy   User    @relation(fields: [createdById], references: [id])
  project     Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
}

// ─────────────────────────────────────────────
// DOCUMENTS
// ─────────────────────────────────────────────

model ProjectDocument {
  id        String       @id @default(cuid())
  projectId String
  type      DocumentType
  title     String
  content   String?
  pdfUrl    String?
  version   Int          @default(1)
  meetingId String?

  createdById String
  createdBy   User    @relation(fields: [createdById], references: [id])
  project     Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─────────────────────────────────────────────
// POST GO LIVE
// ─────────────────────────────────────────────

model PostGoLiveItem {
  id          String             @id @default(cuid())
  projectId   String
  date        DateTime
  type        PostGoLiveItemType
  description String
  status      String             @default("OPEN")
  kpiData     String?

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
}

// ─────────────────────────────────────────────
// LESSONS LEARNED
// ─────────────────────────────────────────────

model LessonLearned {
  id           String          @id @default(cuid())
  projectId    String
  phase        ProjectPhase    @default(EXECUTION)
  area         String
  responsible  String
  occurrence   String
  influence    LessonInfluence @default(POSITIVE)
  impact       LessonImpact    @default(MEDIUM)
  lesson       String
  identifiedAt DateTime        @default(now())
  tags         String?

  createdById String
  createdBy   User    @relation(fields: [createdById], references: [id])
  project     Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─────────────────────────────────────────────
// COMMENTS & ATTACHMENTS
// ─────────────────────────────────────────────

model Comment {
  id        String   @id @default(cuid())
  taskId    String
  userId    String
  content   String

  task        ScheduleTask @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user        User         @relation(fields: [userId], references: [id])
  attachments Attachment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Attachment {
  id        String @id @default(cuid())
  fileName  String
  fileUrl   String
  fileType  String
  fileSize  Int?

  taskId    String?
  commentId String?
  meetingId String?
  projectId String?
  benefitId String?

  task    ScheduleTask?   @relation(fields: [taskId],    references: [id], onDelete: Cascade)
  comment Comment?        @relation(fields: [commentId], references: [id], onDelete: Cascade)
  meeting Meeting?        @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  project Project?        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  benefit ProjectBenefit? @relation(fields: [benefitId], references: [id], onDelete: Cascade)

  uploadedAt DateTime @default(now())
}

// ─────────────────────────────────────────────
// NOTIFICATIONS
// ─────────────────────────────────────────────

model Notification {
  id      String  @id @default(cuid())
  userId  String
  type    String
  title   String
  message String
  link    String?
  read    Boolean @default(false)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
}

model NotificationPreference {
  id     String @id @default(cuid())
  userId String @unique

  // Eventos de projeto
  projectDeadline  Boolean @default(true)   // prazo se aproximando (7 dias)
  projectOnHold    Boolean @default(true)   // projeto pausado
  projectCompleted Boolean @default(false)  // projeto concluído

  // Eventos de atividade
  taskOverdue      Boolean @default(true)   // tarefa atrasada
  taskAssigned     Boolean @default(true)   // tarefa atribuída a mim

  // Eventos de reunião
  checkpointAdded  Boolean @default(true)   // checkpoint registrado no projeto
  meetingAdded     Boolean @default(false)  // qualquer reunião registrada

  // Riscos
  criticalRisk     Boolean @default(true)   // risco crítico identificado

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─────────────────────────────────────────────
// SCHEDULE TEMPLATES — Modelos de Cronograma
// ─────────────────────────────────────────────

model ScheduleTemplate {
  id          String  @id @default(cuid())
  name        String
  description String?
  projectType String  // "AUTOMACAO" | "QUALIDADE" | "CERTIFICACAO" | "EXTERNO" | "CUSTOM"
  color       String?
  isBuiltIn   Boolean @default(false)

  tasks       ScheduleTemplateTask[]

  createdById String
  createdBy   User   @relation(fields: [createdById], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ScheduleTemplateTask {
  id               String  @id @default(cuid())
  templateId       String
  wbsCode          String  // "1", "1.1", "1.1.1"
  parentCode       String? // wbsCode do pai (null = raiz)
  title            String
  estimatedEffort  Float?
  isMilestone      Boolean @default(false)
  predecessorCodes String? // JSON: ["1.1","2.3"]
  durationDays     Int     @default(1)
  order            Int     @default(0)

  template ScheduleTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
}

// ─────────────────────────────────────────────
// BENEFITS — Benefícios e Valor Gerado
// ─────────────────────────────────────────────

model ProjectBenefit {
  id              String           @id @default(cuid())
  projectId       String
  category        BenefitCategory
  type            BenefitType
  description     String
  unit            String           @default("R$")
  plannedValue    Float            @default(0)
  realizedValue   Float            @default(0)
  frequency       BenefitFrequency @default(ONCE)
  baselineDate    DateTime?
  realizationDate DateTime?
  evidence        String?
  status          BenefitStatus    @default(PLANNED)
  customTypeName  String?
  createdById     String
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  project      Project              @relation(fields: [projectId],   references: [id], onDelete: Cascade)
  createdBy    User                 @relation(fields: [createdById], references: [id])
  measurements BenefitMeasurement[]
  attachments  Attachment[]
}

model BenefitMeasurement {
  id            String   @id @default(cuid())
  benefitId     String
  measuredAt    DateTime
  measuredValue Float
  notes         String?
  createdById   String
  createdAt     DateTime @default(now())

  benefit   ProjectBenefit @relation(fields: [benefitId],   references: [id], onDelete: Cascade)
  createdBy User           @relation(fields: [createdById], references: [id])
}

// ─────────────────────────────────────────────
// S-CURVE — Curva S / Baselines de Replanejamento
// ─────────────────────────────────────────────

model ProjectBaseline {
  id          String   @id @default(cuid())
  projectId   String
  number      Int      // 0 = original, 1 = 1º replanejamento, etc.
  name        String
  description String?
  reason      String?  // motivo do replanejamento
  createdById String?
  createdAt   DateTime @default(now())

  project   Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdBy User?          @relation(fields: [createdById], references: [id])
  snaps     BaselineSnap[]

  @@unique([projectId, number])
}

model BaselineSnap {
  id           String    @id @default(cuid())
  baselineId   String
  taskId       String
  taskTitle    String
  plannedStart DateTime?
  plannedEnd   DateTime
  budgetedCost Float?

  baseline ProjectBaseline @relation(fields: [baselineId], references: [id], onDelete: Cascade)
}

// ─────────────────────────────────────────────
// ORGANIZATION CONFIG (singleton row)
// ─────────────────────────────────────────────

model OrgConfig {
  id          String  @id @default("singleton")
  name        String  @default("Planner")
  logoUrl     String?
  sector      String?
  website     String?
  // JSON: Record<"TECNOLOGIA"|"QUALIDADE"|"ESTRATEGICO", {label,color,description,icon}>
  areaConfigs String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
